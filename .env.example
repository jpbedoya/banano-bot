# ── AI Provider ───────────────────────────────────────────────────────────────
# AI_PROVIDER: "anthropic" (default) or "openai"
AI_PROVIDER=openai

# AI_MODEL: override the default model for your provider
# Defaults: anthropic → claude-haiku-4-5, openai → gpt-4o-mini
# AI_MODEL=gpt-4o-mini

# API key for your chosen provider (only one needed)
# ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# ── Discord (Option B only — not needed if running inside OpenClaw) ───────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Vibe Monitoring ──────────────────────────────────────────────────────────
# Comma-separated channel IDs for vibe monitoring (leave empty for mention-only)
WATCHED_CHANNEL_IDS=

# Channel ID where Banano quietly posts serious flags for mods
MOD_CHANNEL_ID=

# Sentiment threshold — messages scoring below this get sent to AI for review
# Default: -2 (only catches clearly negative messages)
SENTIMENT_THRESHOLD=-2
