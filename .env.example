# ── Vibe Monitoring (both options) ───────────────────────────────────────────
# Comma-separated channel IDs for vibe monitoring
WATCHED_CHANNEL_IDS=1483389953089077359

# Channel ID where Banano quietly posts serious flags for mods
MOD_CHANNEL_ID=1483389841835167866

# Sentiment threshold — messages scoring at or below this go to AI review
# -2 = conservative (recommended), -1 = more sensitive, 0 = noisy
SENTIMENT_THRESHOLD=-2

# ── Option B only (not needed for OpenClaw Option A) ─────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# AI provider: "openai" or "anthropic"
AI_PROVIDER=openai

# Model override (defaults: openai → gpt-4o-mini, anthropic → claude-haiku-4-5)
# AI_MODEL=gpt-4o-mini

# API key for chosen provider
OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
