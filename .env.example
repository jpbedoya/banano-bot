# Discord bot token from discord.com/developers
DISCORD_TOKEN=your_discord_bot_token_here

# Anthropic API key (not needed if running inside OpenClaw)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: comma-separated channel IDs for vibe monitoring
# Leave empty for mention-only mode
WATCHED_CHANNEL_IDS=

# Optional: channel ID where Banano quietly posts serious flags for mods
MOD_CHANNEL_ID=

# Sentiment threshold — messages scoring below this get sent to Haiku for review
# Default: -2 (only catches clearly negative messages)
SENTIMENT_THRESHOLD=-2
